    [Fact]
    public async Task GetEventStatistics_WhenEventExists_ReturnsStatistics()
    {
        // Arrange
        var evt = new Event
        {
            Id = 1,
            Name = "Test Event",
            TierId = 1,
            TotalTicketing = 100
        };

        var tickets = new List<Ticket>
        {
            new() { Id = 1, EventId = 1, Price = 50m, Status = TicketStatus.Active },
            new() { Id = 2, EventId = 1, Price = 50m, Status = TicketStatus.Used },
            new() { Id = 3, EventId = 1, Price = 50m, Status = TicketStatus.Cancelled }
        };

        _mockEventRepo.Setup(r => r.GetByIdAsync(1)).ReturnsAsync(evt);
        _mockTicketRepo.Setup(r => r.GetByEventIdRawAsync(1)).ReturnsAsync(tickets);

        // Act
        var result = await _controller.GetEventStatistics(1);

        // Assert
        result.Result.Should().BeOfType<OkObjectResult>();
        var okResult = result.Result as OkObjectResult;
        var stats = okResult!.Value as TicketStatistics;
        stats!.TotalTicketsSold.Should().Be(3);
        stats.TotalTicketsActive.Should().Be(1);
        stats.TotalTicketsUsed.Should().Be(1);
        stats.TotalTicketsCancelled.Should().Be(1);
        stats.TotalRevenue.Should().Be(100m); // Active + Used = 2 * 50
        stats.AvailableTickets.Should().Be(97);
    }
