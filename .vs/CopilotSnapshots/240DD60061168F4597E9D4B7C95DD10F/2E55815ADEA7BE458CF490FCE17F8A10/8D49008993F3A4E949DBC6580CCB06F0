    [Fact]
    public async Task PurchaseTickets_WhenValid_ReturnsCreatedResult()
    {
        // Arrange
        var evt = new Event
        {
            Id = 1,
            Name = "Test Event",
            TierId = 1,
            TotalTicketing = 100,
            EventTierCategories = new List<EventTierCategory>
            {
                new() { EventId = 1, TierCategoryId = 1 }
            }
        };

        var category = new TierCategory
        {
            Id = 1,
            TierId = 1,
            Name = "VIP"
        };

        var request = new PurchaseTicketRequest
        {
            EventId = 1,
            CategoryId = 1,
            Quantity = 2,
            BuyerName = "John Doe",
            BuyerEmail = "john@example.com"
        };

        _mockEventRepo.Setup(r => r.GetByIdAsync(1)).ReturnsAsync(evt);
        _mockTierCategoryRepo.Setup(r => r.GetByIdAsync(1)).ReturnsAsync(category);
        _mockTicketRepo.Setup(r => r.CountByEventAndCategoryAsync(1, 1)).ReturnsAsync(0);
        _mockUow.Setup(u => u.SaveChangesAsync()).ReturnsAsync(2);

        // Act
        var result = await _controller.PurchaseTickets(request);

        // Assert
        result.Result.Should().BeOfType<CreatedAtActionResult>();
        var createdResult = result.Result as CreatedAtActionResult;
        var response = createdResult!.Value as PurchaseTicketResponse;
        response!.Success.Should().BeTrue();
        response.Tickets.Should().HaveCount(2);
        response.TotalPrice.Should().Be(100m); // 2 tickets * 50
    }

