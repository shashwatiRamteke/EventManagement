# EventManagementApi2 Production Dockerfile
# Multi-stage build for optimal image size and performance
# Includes: Events API + Tickets API (NEW)
# See https://aka.ms/customizecontainer to learn how to customize your debug container

# ============================================================================
# Stage 1: Runtime Base Image
# ============================================================================
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS base
USER $APP_UID
WORKDIR /app

# Expose ports for HTTP and HTTPS
EXPOSE 8080
EXPOSE 8081

# Health check endpoint (for container orchestration)
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD ["curl", "-f", "http://localhost/health", "||", "exit", "1"]

# ============================================================================
# Stage 2: Build Stage
# ============================================================================
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
ARG BUILD_CONFIGURATION=Release

WORKDIR /src

# Copy project files
COPY ["EventManagementApi2/EventManagementApi2/EventManagementApi2.csproj", "EventManagementApi2/EventManagementApi2/"]

# Restore dependencies
RUN dotnet restore "./EventManagementApi2/EventManagementApi2/EventManagementApi2.csproj"

# Copy all source code
COPY . .

# Build the project
WORKDIR "/src/EventManagementApi2/EventManagementApi2"
RUN dotnet build "./EventManagementApi2.csproj" -c $BUILD_CONFIGURATION -o /app/build

# ============================================================================
# Stage 3: Publish Stage
# ============================================================================
FROM build AS publish
ARG BUILD_CONFIGURATION=Release

# Publish the application with trimming for smaller image
RUN dotnet publish "./EventManagementApi2.csproj" \
    -c $BUILD_CONFIGURATION \
    -o /app/publish \
    /p:UseAppHost=false \
    /p:PublishTrimmed=false \
    /p:PublishReadyToRun=true

# ============================================================================
# Stage 4: Final Production Image
# ============================================================================
FROM base AS final
WORKDIR /app

# Metadata labels for container identification
LABEL version="2.0" \
      description="EventManagement API with Ticket Purchase System" \
      maintainer="Event Management Team" \
      api.version="2.0" \
      features="Events,Tickets,Categories,Analytics"

# Production environment configuration
ENV ASPNETCORE_ENVIRONMENT=Production
ENV ASPNETCORE_URLS=http://+:80
ENV Logging__LogLevel__Default=Information
ENV Logging__LogLevel__Microsoft__AspNetCore=Warning

# Security: Run as non-root user
USER $APP_UID

# Copy published application
COPY --from=publish /app/publish .

# Application entry point
ENTRYPOINT ["dotnet", "EventManagementApi2.dll"]